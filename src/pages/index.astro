---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import PostCard from '../components/PostCard';
import ParticlesBackground from '../components/ParticlesBackground';
import TagFilters from '../components/TagFilters';
import { BLOG_NAME, SITE_DESCRIPTION, HOME_PAGE, NAVBAR, FEATURES } from '../config';
import { Search } from 'lucide-react';
import { calculateReadingTime } from '../utils/readingTime';
import { generateShortId } from '../utils/slug';

// Function to convert markdown to plain text for search
function markdownToPlainText(markdown: string): string {
  return markdown
    .replace(/```[\s\S]*?```/g, '')
    .replace(/`[^`]+`/g, '')
    .replace(/!\[([^\]]*)\]\([^\)]+\)/g, '')
    .replace(/\[([^\]]+)\]\([^\)]+\)/g, '$1')
    .replace(/^#{1,6}\s+(.+)$/gm, '$1')
    .replace(/\*\*([^*]+)\*\*/g, '$1')
    .replace(/\*([^*]+)\*/g, '$1')
    .replace(/__([^_]+)__/g, '$1')
    .replace(/_([^_]+)_/g, '$1')
    .replace(/^---$/gm, '')
    .replace(/^[\s]*[-*+]\s+/gm, '')
    .replace(/^[\s]*\d+\.\s+/gm, '')
    .replace(/^>\s+/gm, '')
    .replace(/<[^>]+>/g, '')
    .replace(/\s+/g, ' ')
    .trim();
}

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => {
  const dateA = new Date(a.data.date.replace(/年|月|日/g, '/'));
  const dateB = new Date(b.data.date.replace(/年|月|日/g, '/'));
  return dateB.getTime() - dateA.getTime();
});

const allTags = Array.from(new Set(posts.flatMap(post => post.data.tags))).sort();
const postsPerPage = HOME_PAGE.postsPerPage;
---

<BaseLayout title={BLOG_NAME}>
  <div class="min-h-screen relative flex flex-col" id="app">
    {HOME_PAGE.showParticles && FEATURES.particles && <ParticlesBackground client:idle />}
    
    <Navbar 
      client:load
      currentPath="/"
      searchQuery=""
      setSearchQuery={() => {}}
    />

    <main class="flex-1 flex flex-col relative w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 sm:pt-24 z-10 overflow-x-hidden">
      <div class="space-y-6 animate-in fade-in slide-in-from-bottom-4 duration-700">
        <div class="text-center py-6 sm:py-10">
          <div id="search-header" class="hidden">
            <p class="text-slate-500 dark:text-slate-400 mb-2 text-sm font-medium uppercase tracking-widest">搜索结果</p>
            <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white font-serif" id="search-query"></h1>
          </div>
          <div id="normal-header">
            <div class="relative w-full max-w-4xl mx-auto">
              <div class="relative">
                <div class="space-y-4 w-full max-w-xl mx-auto">
                  {(() => {
                    const verse = HOME_PAGE.verse;
                    if (verse.includes('\n')) {
                      const parts = verse.split('\n');
                      return (
                        <>
                          <div class="text-left">
                            <span class="text-3xl sm:text-5xl font-bold text-slate-900 dark:text-white font-serif leading-tight">{parts[0]}</span>
                          </div>
                            <div class="text-left pl-24 sm:pl-32">
                              <span class="text-3xl sm:text-5xl font-bold text-slate-900 dark:text-white font-serif leading-tight">{parts[1] || ''}</span>
                            </div>
                        </>
                      );
                    }
                    return (
                      <div class="text-left">
                        <span class="text-3xl sm:text-5xl font-bold text-slate-900 dark:text-white font-serif leading-tight">{verse}</span>
                      </div>
                    );
                  })()}
                </div>
                <p class="text-right text-sm sm:text-base text-slate-500 dark:text-slate-400 font-serif italic mt-4 mr-8 sm:mr-12">
                  — {HOME_PAGE.source}
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- 个人信息区域 -->
        <div class="flex items-center gap-4 my-6 animate-in fade-in slide-in-from-bottom-4 duration-700">
          <img 
            src="https://www.wsyblog.cn/IMG_8745.jpeg" 
            alt="王苏洋头像" 
            class="w-14 h-14 sm:w-16 sm:h-16 rounded-full object-cover border-2 border-white dark:border-slate-700 shadow-md"
          />
          <div>
            <h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white">王苏洋</h2>
            <p class="text-sm sm:text-base text-slate-500 dark:text-slate-400">折腾不止，记录不停</p>
          </div>
        </div>

        <!-- 美化后的社交图标区域 -->
        <div class="flex items-center justify-start gap-6 my-4 ml-0 text-slate-600 dark:text-slate-400">
          <a href="https://github.com/suyangb" target="_blank" rel="noopener noreferrer" 
             class="transition-all duration-300 hover:text-black dark:hover:text-white hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
          </a>
          <a href="/feed" target="_blank" rel="noopener noreferrer" 
             class="transition-all duration-300 hover:text-orange-500 hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 11a9 9 0 0 1 9 9"></path>
              <path d="M4 4a16 16 0 0 1 16 16"></path>
              <circle cx="5" cy="19" r="1"></circle>
            </svg>
          </a>
          <a href="mailto:1493367306@qq.com" target="_blank" rel="noopener noreferrer" 
             class="transition-all duration-300 hover:text-red-400 hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9-2-2-2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          </a>
        </div>

        <!-- 分隔线 -->
        <div class="w-full h-px bg-gradient-to-r from-transparent via-slate-200 dark:via-slate-700 to-transparent"></div>

        <div class="relative">
          {HOME_PAGE.showTagFilters && <TagFilters client:idle tags={allTags} />}
          
          <div class="grid grid-cols-1 gap-8 min-h-[200px]" id="posts-container" data-posts-per-page={postsPerPage}>
          {posts.map((post) => {
            const plainTextContent = markdownToPlainText(post.body);
            return (
            <div
              data-post-card
              data-title={post.data.title}
              data-tags={post.data.tags.join(' ')}
              data-description={post.data.summary || ''}
              data-content={plainTextContent}
              data-post-id={post.id}
              class="transition-all duration-500"
            >
              <PostCard 
                client:visible
                post={{
                  id: post.id,
                  title: post.data.title,
                  summary: post.data.summary,
                  date: post.data.date,
                  tags: post.data.tags,
                  readingTime: post.data.readingTime || calculateReadingTime(post.body),
                  slug: generateShortId(post.id),
                }}
              />
            </div>
            );
          })}
          </div>
          
          {postsPerPage > 0 && (
            <div id="pagination" class="hidden flex flex-wrap items-center justify-center gap-1.5 mt-12 mb-8">
            </div>
          )}
        </div>

        <div id="no-results" class="hidden flex-col items-center justify-center py-16 text-center animate-in fade-in duration-500">
          <div class="w-20 h-20 bg-slate-100 dark:bg-white/5 rounded-full flex items-center justify-center mb-6 text-slate-400">
            <Search size={28} />
          </div>
          <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-3">未找到文章</h3>
          <p class="text-slate-500 dark:text-slate-400 mb-8 max-w-md" id="no-results-message"></p>
          <button 
            id="clear-filters"
            class="px-6 py-2.5 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-lg text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-white/10 transition-all duration-300 hover:shadow-md"
          >
            清除所有筛选
          </button>
        </div>
      </div>

      <Footer client:idle />
    </main>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      let initialSearchQuery = '';
      try {
        const pendingQuery = sessionStorage.getItem('pendingSearchQuery');
        if (pendingQuery) {
          initialSearchQuery = pendingQuery;
          sessionStorage.removeItem('pendingSearchQuery');
        } else {
          const urlParams = new URLSearchParams(window.location.search);
          initialSearchQuery = urlParams.get('q') || '';
        }
      } catch (e) {
        const urlParams = new URLSearchParams(window.location.search);
        initialSearchQuery = urlParams.get('q') || '';
      }

      let searchQuery = initialSearchQuery;
      let selectedTag = null;
      let currentPage = 1;
      const postsContainer = document.getElementById('posts-container');
      const postsPerPage = parseInt(postsContainer?.dataset.postsPerPage || '0');

      // 初始化搜索
      if (initialSearchQuery) {
        const initSearch = () => {
          window.dispatchEvent(new CustomEvent('search-updated', {
            detail: { query: initialSearchQuery }
          }));
          setTimeout(() => {
            const searchButton = document.querySelector('button[aria-label="Open search"]');
            const searchInput = document.querySelector('input[type="text"]');
            if (searchButton && !searchInput) searchButton.click();
            if (searchInput) searchInput.value = initialSearchQuery;
          }, 100);
        };
        initSearch();
      }

      // 获取所有文章数据
      function getPostsData() {
        const postsData = [];
        document.querySelectorAll('[data-post-card]').forEach(card => {
          postsData.push({
            id: card.dataset.postId || '',
            title: card.dataset.title || '',
            tags: card.dataset.tags?.split(' ') || [],
            content: card.dataset.content || '',
            element: card
          });
        });
        return postsData;
      }

      // 更新筛选
      function updateFilters() {
        const query = searchQuery.toLowerCase().trim();
        const tag = selectedTag;
        currentPage = 1;

        // 标题切换
        const searchHeader = document.getElementById('search-header');
        const normalHeader = document.getElementById('normal-header');
        const searchQueryEl = document.getElementById('search-query');
        if (query) {
          searchHeader?.classList.remove('hidden');
          normalHeader?.classList.add('hidden');
          if (searchQueryEl) searchQueryEl.textContent = `"${query}"`;
        } else {
          searchHeader?.classList.add('hidden');
          normalHeader?.classList.remove('hidden');
        }

        // 筛选可见文章
        const postsData = getPostsData();
        const visiblePosts = [];
        postsData.forEach(post => {
          const { title, tags, content, element } = post;
          const matchesSearch = !query || 
            title.toLowerCase().includes(query) || 
            tags.some(t => t.toLowerCase().includes(query)) ||
            content.toLowerCase().includes(query);
          const matchesTag = !tag || tags.includes(tag);
          const matches = matchesSearch && matchesTag;

          element.style.display = 'none';
          if (matches) visiblePosts.push(post);
        });

        // 分页显示
        const visibleCount = visiblePosts.length;
        const noResults = document.getElementById('no-results');
        const postsContainer = document.getElementById('posts-container');
        const noResultsMessage = document.getElementById('no-results-message');

        if (visibleCount === 0) {
          noResults?.classList.remove('hidden');
          postsContainer?.classList.add('hidden');
          document.getElementById('pagination')?.classList.add('hidden');
          if (noResultsMessage) {
            if (query && tag) noResultsMessage.textContent = `没有找到同时包含 "${query}" 且带有标签 "${tag}" 的文章。`;
            else if (query) noResultsMessage.textContent = `没有找到包含 "${query}" 的文章。`;
            else if (tag) noResultsMessage.textContent = `没有找到带有标签 "${tag}" 的文章。`;
          }
          return;
        }

        noResults?.classList.add('hidden');
        postsContainer?.classList.remove('hidden');

        // 应用分页
        if (postsPerPage > 0) {
          const totalPages = Math.ceil(visibleCount / postsPerPage);
          const start = (currentPage - 1) * postsPerPage;
          const end = start + postsPerPage;
          const show = visiblePosts.slice(start, end);

          show.forEach((p, i) => {
            p.element.style.display = '';
            p.element.style.animationDelay = `${i * 100}ms`;
            p.element.classList.add('animate-in', 'fade-in', 'slide-in-from-bottom-2');
          });

          updatePagination(totalPages);
        } else {
          visiblePosts.forEach(p => p.element.style.display = '');
          document.getElementById('pagination')?.classList.add('hidden');
        }

        // 标签按钮样式
        document.querySelectorAll('[data-tag-filter]').forEach(btn => {
          const btnTag = btn.dataset.tagFilter || null;
          const isAll = btnTag === '';
          const active = (selectedTag === null && isAll) || (selectedTag === btnTag);

          const activeClasses = ['bg-slate-800','text-white','border-slate-800','dark:bg-white','dark:text-slate-900','dark:border-white','shadow-md'];
          const normalClasses = ['bg-transparent','text-slate-600','border-slate-200','dark:text-slate-400','dark:border-white/10','hover:bg-slate-50','hover:border-docs-accent/50','hover:text-docs-accent','dark:hover:bg-white/5','dark:hover:border-dark-accent/50','dark:hover:text-dark-accent'];

          btn.classList.remove(...activeClasses, ...normalClasses);
          btn.classList.add(active ? activeClasses : normalClasses);
        });
      }

      // 生成分页
      function updatePagination(totalPages) {
        const pagination = document.getElementById('pagination');
        if (!pagination) return;

        if (totalPages <= 1) {
          pagination.classList.add('hidden');
          return;
        }
        pagination.classList.remove('hidden');
        pagination.innerHTML = '';

        // 创建页码按钮
        function mkBtn(n, active = false, ellipsis = false) {
          const b = document.createElement('button');
          if (ellipsis) {
            b.textContent = '…';
            b.disabled = true;
            b.className = 'w-9 h-9 flex items-center justify-center text-sm text-slate-400 dark:text-slate-500';
            return b;
          }
          b.textContent = n;
          b.className = `w-9 h-9 flex items-center justify-center rounded text-sm transition ${
            active 
              ? 'bg-docs-accent text-white dark:bg-dark-accent font-bold' 
              : 'bg-white dark:bg-white/5 text-slate-600 dark:text-slate-400 hover:border-docs-accent hover:text-docs-accent dark:hover:border-dark-accent dark:hover:text-dark-accent'
          }`;
          if (!active) b.onclick = () => goToPage(n);
          return b;
        }

        // 箭头
        function mkArrow(dir, disabled) {
          const b = document.createElement('button');
          b.className = `w-9 h-9 flex items-center justify-center rounded text-sm transition ${
            disabled ? 'text-slate-300 dark:text-slate-600 cursor-not-allowed' 
            : 'text-slate-600 dark:text-slate-400 hover:border-docs-accent hover:text-docs-accent dark:hover:border-dark-accent dark:hover:text-dark-accent'
          }`;
          b.disabled = disabled;
          const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
          svg.setAttribute('viewBox', '0 0 24 24');
          svg.setAttribute('width', '16');
          svg.setAttribute('height', '16');
          svg.setAttribute('stroke', 'currentColor');
          svg.setAttribute('stroke-width', '2');
          svg.setAttribute('stroke-linecap', 'round');
          const pl = document.createElementNS('http://www.w3.org/2000/svg', 'polyline');
          pl.setAttribute('points', dir === 'prev' ? '15 18 9 12 15 6' : '9 18 15 12 9 6');
          svg.append(pl);
          b.append(svg);
          if (!disabled) b.onclick = () => goToPage(dir === 'prev' ? currentPage - 1 : currentPage + 1);
          return b;
        }

        // 页码逻辑
        let pages = [];
        if (totalPages <= 7) {
          for (let i = 1; i <= totalPages; i++) pages.push(i);
        } else {
          pages.push(1);
          if (currentPage <= 3) pages.push(2,3,4,'...', totalPages);
          else if (currentPage >= totalPages - 2) pages.push('...', totalPages-3, totalPages-2, totalPages-1, totalPages);
          else pages.push('...', currentPage-1, currentPage, currentPage+1, '...', totalPages);
        }

        pagination.append(mkArrow('prev', currentPage === 1));
        pages.forEach(p => {
          if (p === '...') pagination.append(mkBtn(0, false, true));
          else pagination.append(mkBtn(p, p === currentPage));
        });
        pagination.append(mkArrow('next', currentPage === totalPages));
      }

      // 跳页
      function goToPage(page) {
        const query = searchQuery.toLowerCase().trim();
        const tag = selectedTag;
        const postsData = getPostsData();
        const visiblePosts = postsData.filter(p => {
          const ms = !query || p.title.toLowerCase().includes(query) || p.tags.some(t => t.toLowerCase().includes(query)) || p.content.toLowerCase().includes(query);
          const mt = !tag || p.tags.includes(tag);
          return ms && mt;
        });

        const totalPages = Math.ceil(visiblePosts.length / postsPerPage);
        if (page < 1 || page > totalPages) return;
        currentPage = page;

        // 隐藏所有
        postsData.forEach(p => p.element.style.display = 'none');

        // 显示当前页
        const start = (currentPage - 1) * postsPerPage;
        const end = start + postsPerPage;
        const show = visiblePosts.slice(start, end);
        show.forEach((p, i) => {
          p.element.style.display = '';
          p.element.style.animationDelay = `${i * 80}ms`;
          p.element.classList.add('animate-in', 'fade-in', 'slide-in-from-bottom-2');
        });

        updatePagination(totalPages);
        postsContainer?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      // 事件监听
      window.addEventListener('tag-filter-changed', e => {
        selectedTag = e.detail.tag === '' ? null : e.detail.tag;
        updateFilters();
      });

      window.addEventListener('search-updated', e => {
        searchQuery = e.detail.query;
        updateFilters();
      });

      // 清除筛选
      document.getElementById('clear-filters')?.addEventListener('click', () => {
        searchQuery = '';
        selectedTag = null;
        const inp = document.querySelector('input[type="text"]');
        if (inp) inp.value = '';
        updateFilters();
      });

      // 初始化
      updateFilters();
      window.dispatchEvent(new CustomEvent('tag-filter-changed', { detail: { tag: '' } }));
    });
  </script>
</BaseLayout>
