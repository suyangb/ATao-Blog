---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import PostCard from '../components/PostCard';
import ParticlesBackground from '../components/ParticlesBackground';
import TagFilters from '../components/TagFilters';
import { BLOG_NAME, SITE_DESCRIPTION, HOME_PAGE, NAVBAR, FEATURES } from '../config';
import { Search } from 'lucide-react';
import { calculateReadingTime } from '../utils/readingTime';
import { generateShortId } from '../utils/slug';

function markdownToPlainText(markdown: string): string {
  return markdown
    .replace(/```[\s\S]*?```/g, '')
    .replace(/`[^`]+`/g, '')
    .replace(/!\[([^\]]*)\]\([^\)]+\)/g, '')
    .replace(/\[([^\]]+)\]\([^\)]+\)/g, '$1')
    .replace(/^#{1,6}\s+(.+)$/gm, '$1')
    .replace(/\*\*([^*]+)\*\*/g, '$1')
    .replace(/\*([^*]+)\*/g, '$1')
    .replace(/__([^_]+)__/g, '$1')
    .replace(/_([^_]+)_/g, '$1')
    .replace(/^---$/gm, '')
    .replace(/^[\s]*[-*+]\s+/gm, '')
    .replace(/^[\s]*\d+\.\s+/gm, '')
    .replace(/^>\s+/gm, '')
    .replace(/<[^>]+>/g, '')
    .replace(/\s+/g, ' ')
    .trim();
}

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => {
  const dateA = new Date(a.data.date.replace(/年|月|日/g, '/'));
  const dateB = new Date(b.data.date.replace(/年|月|日/g, '/'));
  return dateB.getTime() - dateA.getTime();
});

const allTags = Array.from(new Set(posts.flatMap(post => post.data.tags))).sort();
const postsPerPage = HOME_PAGE.postsPerPage;
---

<BaseLayout title={BLOG_NAME}>
<div class="min-h-screen relative flex flex-col" id="app">
  {HOME_PAGE.showParticles && FEATURES.particles && <ParticlesBackground client:idle />}

  <Navbar
    client:load
    currentPath="/"
    searchQuery=""
    setSearchQuery={() => {}}
  />

  <main class="flex-1 relative w-full max-w-4xl mx-auto px-5 sm:px-8 pt-24 pb-20 z-10">
    <div class="space-y-12">

      <!-- 顶部标题诗句区域 -->
      <div class="text-center mb-10 animate-fade-in">
        <div id="search-header" class="hidden">
          <p class="text-sm font-medium text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-1">搜索结果</p>
          <h1 class="text-3xl font-bold text-slate-900 dark:text-white" id="search-query"></h1>
        </div>

        <div id="normal-header">
          <div class="mx-auto max-w-2xl text-left">
            {
              HOME_PAGE.verse.includes('\n')
                ? (
                  <div class="space-y-2">
                    {HOME_PAGE.verse.split('\n').map((line, i) => (
                      <p
                        key={i}
                        class="text-3xl sm:text-5xl font-bold text-slate-900 dark:text-white font-serif leading-tight"
                      >
                        {line}
                      </p>
                    ))}
                  </div>
                )
                : (
                  <p class="text-3xl sm:text-5xl font-bold text-slate-900 dark:text-white font-serif leading-tight">
                    {HOME_PAGE.verse}
                  </p>
                )
            }
            <p class="text-right text-sm text-slate-500 dark:text-slate-400 italic mt-4">
              — {HOME_PAGE.source}
            </p>
          </div>
        </div>
      </div>

      <!-- 个人信息卡片 -->
      <div class="bg-white/80 dark:bg-slate-900/80 backdrop-blur-md rounded-2xl p-6 shadow-sm border border-slate-200 dark:border-slate-800 flex items-center gap-5">
        <img
          src="https://www.wsyblog.cn/IMG_8745.jpeg"
          alt="王苏洋"
          class="w-16 h-16 rounded-full object-cover shadow-md border-2 border-white dark:border-slate-700"
        />
        <div>
          <h2 class="text-xl font-bold text-slate-900 dark:text-white">王苏洋</h2>
          <p class="text-slate-500 dark:text-slate-400 mt-0.5">折腾不止，记录不停</p>
        </div>
      </div>

      <!-- 社交链接 -->
      <div class="flex gap-5 text-lg text-slate-600 dark:text-slate-400">
        <a
          href="https://github.com/suyangb"
          target="_blank"
          class="p-2 rounded-xl hover:bg-slate-100 dark:hover:bg-slate-800 transition-all hover:scale-105"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
        </a>
        <a
          href="/feed"
          target="_blank"
          class="p-2 rounded-xl hover:bg-orange-50 dark:hover:bg-orange-950/30 text-orange-500 transition-all hover:scale-105"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11a9 9 0 0 1 9 9"></path>
            <path d="M4 4a16 16 0 0 1 16 16"></path>
            <circle cx="5" cy="19" r="1"></circle>
          </svg>
        </a>
        <a
          href="mailto:1493367306@qq.com"
          class="p-2 rounded-xl hover:bg-red-50 dark:hover:bg-red-950/30 text-red-400 transition-all hover:scale-105"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9-2-2-2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
        </a>
      </div>

      <!-- 分隔线 -->
      <div class="h-px bg-gradient-to-r from-transparent via-slate-200 dark:via-slate-700 to-transparent"></div>

      <!-- 标签 + 文章列表 -->
      <div class="space-y-8">
        {HOME_PAGE.showTagFilters && <TagFilters client:idle tags={allTags} />}

        <div
          class="grid grid-cols-1 gap-6 md:gap-8"
          id="posts-container"
          data-posts-per-page={postsPerPage}
        >
          {posts.map((post) => {
            const plainTextContent = markdownToPlainText(post.body);
            return (
              <div
                data-post-card
                data-title={post.data.title}
                data-tags={post.data.tags.join(' ')}
                data-description={post.data.summary || ''}
                data-content={plainTextContent}
                data-post-id={post.id}
                class="transition-all duration-500"
              >
                <PostCard
                  client:visible
                  post={{
                    id: post.id,
                    title: post.data.title,
                    summary: post.data.summary,
                    date: post.data.date,
                    tags: post.data.tags,
                    readingTime: post.data.readingTime || calculateReadingTime(post.body),
                    slug: generateShortId(post.id),
                  }}
                />
              </div>
            );
          })}
        </div>

        {postsPerPage > 0 && (
          <div id="pagination" class="hidden flex flex-wrap items-center justify-center gap-1.5 mt-12"></div>
        )}
      </div>

      <!-- 无搜索结果 -->
      <div id="no-results" class="hidden flex-col items-center justify-center py-16 text-center">
        <div class="w-20 h-20 bg-slate-100 dark:bg-slate-800/50 rounded-full flex items-center justify-center text-slate-400 mb-6">
          <Search size={28} />
        </div>
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-2">未找到文章</h3>
        <p class="text-slate-500 dark:text-slate-400 max-w-md mb-8" id="no-results-message"></p>
        <button
          id="clear-filters"
          class="px-6 py-2.5 rounded-xl bg-white dark:bg-slate-800/70 border border-slate-200 dark:border-slate-700 text-sm font-medium hover:shadow-md transition-all"
        >
          清除所有筛选
        </button>
      </div>

    </div>

    <Footer client:idle class="mt-20" />
  </main>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  let initialSearchQuery = '';
  try {
    const pendingQuery = sessionStorage.getItem('pendingSearchQuery');
    if (pendingQuery) {
      initialSearchQuery = pendingQuery;
      sessionStorage.removeItem('pendingSearchQuery');
    } else {
      const urlParams = new URLSearchParams(window.location.search);
      initialSearchQuery = urlParams.get('q') || '';
    }
  } catch (e) {
    const urlParams = new URLSearchParams(window.location.search);
    initialSearchQuery = urlParams.get('q') || '';
  }

  let searchQuery = initialSearchQuery;
  let selectedTag = null;
  let currentPage = 1;
  const postsContainer = document.getElementById('posts-container');
  const postsPerPage = parseInt(postsContainer?.dataset.postsPerPage || '0');

  if (initialSearchQuery) {
    setTimeout(() => {
      window.dispatchEvent(new CustomEvent('search-updated', { detail: { query: initialSearchQuery } }));
      const input = document.querySelector('input[type="text"]');
      if (input) input.value = initialSearchQuery;
    }, 100);
  }

  function getPostsData() {
    return Array.from(document.querySelectorAll('[data-post-card]')).map(card => ({
      id: card.dataset.postId || '',
      title: card.dataset.title || '',
      tags: card.dataset.tags?.split(' ') || [],
      content: card.dataset.content || '',
      element: card
    }));
  }

  function updateFilters() {
    const query = searchQuery.toLowerCase().trim();
    const tag = selectedTag;
    currentPage = 1;

    const searchHeader = document.getElementById('search-header');
    const normalHeader = document.getElementById('normal-header');
    const searchQueryEl = document.getElementById('search-query');

    if (query) {
      searchHeader?.classList.remove('hidden');
      normalHeader?.classList.add('hidden');
      if (searchQueryEl) searchQueryEl.textContent = `"${query}"`;
    } else {
      searchHeader?.classList.add('hidden');
      normalHeader?.classList.remove('hidden');
    }

    const postsData = getPostsData();
    const visiblePosts = [];

    postsData.forEach(post => {
      const { title, tags, content } = post;
      const matchSearch = !query
        || title.toLowerCase().includes(query)
        || tags.some(t => t.toLowerCase().includes(query))
        || content.toLowerCase().includes(query);
      const matchTag = !tag || tags.includes(tag);

      post.element.style.display = matchSearch && matchTag ? '' : 'none';
      if (matchSearch && matchTag) visiblePosts.push(post);
    });

    const noResults = document.getElementById('no-results');
    const noResultsMessage = document.getElementById('no-results-message');

    if (visiblePosts.length === 0) {
      noResults?.classList.remove('hidden');
      postsContainer?.classList.add('hidden');
      document.getElementById('pagination')?.classList.add('hidden');
      if (noResultsMessage) {
        if (query && tag) noResultsMessage.textContent = `没有找到同时包含 "${query}" 且带有标签 "${tag}" 的文章。`;
        else if (query) noResultsMessage.textContent = `没有找到包含 "${query}" 的文章。`;
        else if (tag) noResultsMessage.textContent = `没有找到带有标签 "${tag}" 的文章。`;
      }
      return;
    }

    noResults?.classList.add('hidden');
    postsContainer?.classList.remove('hidden');

    if (postsPerPage > 0) {
      const totalPages = Math.ceil(visiblePosts.length / postsPerPage);
      const show = visiblePosts.slice(0, postsPerPage);
      show.forEach((p, i) => {
        p.element.style.animationDelay = `${i * 80}ms`;
        p.element.classList.add('animate-fade-in', 'animate-slide-up');
      });
      updatePagination(totalPages);
    }

    // 标签按钮高亮
    document.querySelectorAll('[data-tag-filter]').forEach(btn => {
      const t = btn.dataset.tagFilter;
      const isActive = (selectedTag === null && t === '') || (selectedTag === t);
      btn.classList.toggle('bg-slate-900 text-white dark:bg-white dark:text-slate-900', isActive);
      btn.classList.toggle('bg-transparent text-slate-600 dark:text-slate-400', !isActive);
    });
  }

  function updatePagination(totalPages) {
    const pagination = document.getElementById('pagination');
    if (!pagination) return;
    if (totalPages <= 1) { pagination.classList.add('hidden'); return; }
    pagination.classList.remove('hidden');
    pagination.innerHTML = '';

    const createBtn = (text, isActive = false, onClick = null) => {
      const b = document.createElement('button');
      b.className = `w-10 h-10 rounded-lg flex items-center justify-center text-sm font-medium transition-all ${
        isActive
          ? 'bg-slate-900 text-white dark:bg-white dark:text-slate-900'
          : 'bg-white/80 dark:bg-slate-800/80 text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700'
      }`;
      b.textContent = text;
      if (onClick) b.addEventListener('click', onClick);
      return b;
    };

    const prev = createBtn('←', currentPage === 1, () => goToPage(currentPage - 1));
    prev.disabled = currentPage === 1;
    pagination.appendChild(prev);

    for (let i = 1; i <= totalPages; i++) {
      if (totalPages > 7 && i > 1 && i < totalPages && Math.abs(i - currentPage) > 1) continue;
      pagination.appendChild(createBtn(i.toString(), i === currentPage, () => goToPage(i)));
    }

    const next = createBtn('→', currentPage === totalPages, () => goToPage(currentPage + 1));
    next.disabled = currentPage === totalPages;
    pagination.appendChild(next);
  }

  function goToPage(page) {
    const postsData = getPostsData();
    const q = searchQuery.toLowerCase();
    const tag = selectedTag;
    const visible = postsData.filter(p => {
      const ms = !q || p.title.toLowerCase().includes(q) || p.tags.some(t => t.toLowerCase().includes(q)) || p.content.toLowerCase().includes(q);
      const mt = !tag || p.tags.includes(tag);
      return ms && mt;
    });

    const totalPages = Math.ceil(visible.length / postsPerPage);
    if (page < 1 || page > totalPages) return;
    currentPage = page;

    postsData.forEach(p => p.element.style.display = 'none');
    const show = visible.slice((currentPage - 1) * postsPerPage, currentPage * postsPerPage);
    show.forEach(p => p.element.style.display = '');

    updatePagination(totalPages);
    postsContainer?.scrollIntoView({ behavior: 'smooth' });
  }

  window.addEventListener('tag-filter-changed', e => {
    selectedTag = e.detail.tag || null;
    updateFilters();
  });

  window.addEventListener('search-updated', e => {
    searchQuery = e.detail.query;
    updateFilters();
  });

  document.getElementById('clear-filters')?.addEventListener('click', () => {
    searchQuery = '';
    selectedTag = null;
    const inp = document.querySelector('input[type="text"]');
    if (inp) inp.value = '';
    updateFilters();
  });

  updateFilters();
  window.dispatchEvent(new CustomEvent('tag-filter-changed', { detail: { tag: '' } }));
});
</script>
</BaseLayout>
